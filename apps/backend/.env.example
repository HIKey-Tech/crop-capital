# Server
PORT=5123

# Database
MONGO_URI=mongodb://localhost:27017/cropcapital

# Authentication
JWT_SECRET=jwt_secret

# Paystack (https://dashboard.paystack.com/#/settings/developer)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx

# Email (Resend)
# EMAIL_PASS is your Resend API key.
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_USER=resend
EMAIL_PASS=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=cloud-name
CLOUDINARY_API_KEY=api-key
CLOUDINARY_API_SECRET=api-secret

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Tenancy
TENANCY_STRICT_MODE=true
PLATFORM_ROOT_DOMAIN=yourplatform.com
TENANT_HEADER_SECRET=your-internal-header-secret
TENANT_CACHE_TTL_SECONDS=30
CROPCAPITAL_TENANT_DOMAINS=app.cropcapital.com,cropcapital.com
CROPCAPITAL_SUPER_ADMIN_EMAIL=admin@cropcapital.com
